[Unit]
Description=Pitch Tank FastAPI Backend
After=network.target

[Service]
Type=simple
User=highspeed
Group=highspeed
WorkingDirectory=/opt/pitch-tank/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /opt/pitch-tank/backend/main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
